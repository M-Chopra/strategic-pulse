# Production Environment - Update these with your actual values before deploying to Render

# MongoDB Connection (use your MongoDB Atlas connection string)
MONGO_URI=mongodb+srv://root:Admin1234@cluster0.jttj0qd.mongodb.net/strategic-pulse?appName=Cluster0

# JWT Secrets (change these to long random strings for production)
JWT_SECRET=your_production_jwt_secret_key_generate_random_string_here
JWT_REFRESH_SECRET=your_production_refresh_secret_key_generate_random_string_here

# Admin Credentials (change these for production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password_in_production

# NewsAPI Key
NEWS_API_KEY=739f51d2a11b47c4bd046d08e64538fc

# OpenAI API Key (optional, for AI summaries)
OPENAI_API_KEY=your_openai_key_here

# Port (Render will set this automatically, but can be overridden)
PORT=5000

# Node environment
NODE_ENV=production
